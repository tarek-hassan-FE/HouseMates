# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Remote migrations (choose one method):
# SUPABASE_ACCESS_TOKEN=   # from https://supabase.com/dashboard/account/tokens → then npm run db:push
# SUPABASE_DB_URL=         # Database URI — encode @ in password as %40 (e.g. pass@word → pass%40word)

# Optional: copy to .env.local or .env (both work; .env.local overrides .env)
